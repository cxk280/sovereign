{
  "title": "sovereign — gateway",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests/sec by task",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum by (task) (rate(sovereign_gateway_requests_total{status=\"ok\"}[5m]))", "legendFormat": "{{task}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 latency (s) by model",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, model) (rate(sovereign_gateway_request_latency_seconds_bucket[5m])))", "legendFormat": "{{model}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tokens/sec",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum by (kind) (rate(sovereign_gateway_tokens_total[5m]))", "legendFormat": "{{kind}}" }
      ]
    },
    {
      "type": "stat",
      "title": "Error rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(rate(sovereign_gateway_requests_total{status=\"error\"}[5m])) / sum(rate(sovereign_gateway_requests_total[5m]))" }
      ]
    }
  ]
}
