# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.uv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Environment / secrets (never commit real values — see .env.example)
.env
.env.*
!.env.example
*.pem
*.key

# Models & artifacts (large; never commit weights)
models/
*.gguf
*.safetensors
*.bin

# Vector store / local data
qdrant_storage/
*.duckdb
*.sqlite

# Node / dashboard
node_modules/
dashboard/dist/
dashboard/.vite/

# Terraform
infra/**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log

# OS / editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Eval / reports output (generated)
eval/results/*.json
!eval/results/.gitkeep
