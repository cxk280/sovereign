# ── sovereign environment (copy to .env; NEVER commit real values) ─────────────

# --- Gateway ---
SOVEREIGN_GATEWAY_HOST=0.0.0.0
SOVEREIGN_GATEWAY_PORT=8080
# Path to the model registry file that defines models, quant levels, routing.
SOVEREIGN_REGISTRY_PATH=./gateway/registry.yaml

# --- Local inference backend ($0 dev path) ---
# One of: ollama | llamacpp
SOVEREIGN_LOCAL_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
LLAMACPP_BASE_URL=http://localhost:8081

# --- Vultr GPU inference target (production; not used in local $0 dev) ---
# OpenAI-compatible vLLM endpoint served on Vultr Cloud GPU.
VLLM_BASE_URL=
VLLM_API_KEY=

# --- RAG / vector store ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- GitLab CI integration (set in GitLab CI/CD variables, not here) ---
GITLAB_TOKEN=
CI_API_V4_URL=
SOVEREIGN_GATEWAY_URL=http://localhost:8080

# --- Vultr (Terraform; export as TF_VAR_* or set in a .tfvars you do NOT commit) ---
VULTR_API_KEY=
